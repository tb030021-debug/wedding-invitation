generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GuestbookSide {
  GROOM_SIDE
  BRIDE_SIDE
}

model Wedding {
  id           String             @id @default(cuid())
  groomName    String
  brideName    String
  weddingDate  DateTime
  weddingTime  String
  venueName    String
  venueAddress String
  messages     GuestbookMessage[]
  guestPhotos  GuestPhoto[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model GuestbookMessage {
  id           String        @id @default(cuid())
  weddingId    String
  wedding      Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  name         String
  side         GuestbookSide
  message      String
  passwordHash String
  isHidden     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([weddingId, createdAt])
  @@index([weddingId, isHidden, createdAt])
  @@index([weddingId, side, createdAt])
}

model GuestPhoto {
  id           String   @id @default(cuid())
  weddingId    String
  wedding      Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  uploaderName String
  originalName String
  mimeType     String
  size         Int
  imageData    Bytes
  createdAt    DateTime @default(now())

  @@index([weddingId, createdAt])
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
