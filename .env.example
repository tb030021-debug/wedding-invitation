# External PostgreSQL database connection string used by Prisma.
# Supabase/Neon/Railway example:
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Admin seed account. Change both values before production deployment.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-this-password"

# Used to sign the httpOnly admin login cookie. Use a long random string in production.
AUTH_SECRET="change-this-random-secret"

# Kakao Developers application JavaScript key used by Kakao Talk Share.
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=""

# Local wedding invitation URL. Replace this with the deployed URL on Vercel.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional. Vercel sets this automatically for production builds.
NODE_ENV="production"
